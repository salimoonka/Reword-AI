# Supabase Configuration
# Copy to config.toml and adjust values

[api]
enabled = true
port = 54321
schemas = ["public"]
extra_search_path = ["public"]
max_rows = 1000

[db]
port = 54322
major_version = 15

[studio]
enabled = true
port = 54323

[auth]
enabled = true
site_url = "https://reword-website.onrender.com" # Production website URL
additional_redirect_urls = [
  "rewordai://auth/callback",                                  # Mobile deep link (prod)
  "https://reword-website.onrender.com/auth/app-complete",     # Mobile OAuth via website (prod)
  "https://reword-website.onrender.com/auth/callback",         # Website OAuth callback (prod)
  "exp://localhost:8081/--/auth/callback"                       # Expo dev deep link
]

[auth.email]
enable_signup = true
double_confirm_changes = true
enable_confirmations = false # Disable for development

[auth.external.apple]
enabled = true
client_id = "env(APPLE_CLIENT_ID)"
secret = "env(APPLE_SECRET)"

[storage]
enabled = false # Not needed for initial MVP

[realtime]
enabled = false # Not needed for initial MVP
